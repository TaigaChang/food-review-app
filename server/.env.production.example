# Railway Production Environment Variables
# These should be automatically set by Railway when connecting services

# Database connection string (auto-injected by Railway MySQL plugin)
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@hostname:3306/railway

# Node environment
NODE_ENV=production

# JWT secret for authentication
JWT_SECRET=your-secret-key-here

# Optional: Express port (Railway auto-assigns this)
PORT=8080

# Optional: Database settings (used as fallback if DATABASE_URL not available)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=food_review_app
