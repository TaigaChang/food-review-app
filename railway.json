{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd server && npm install --omit=dev"
  },
  "deploy": {
    "startCommand": "cd server && node simple.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
